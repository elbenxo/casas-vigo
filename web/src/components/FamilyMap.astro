---
import { t, type Lang } from '../i18n/translations';
import { familyMapPoints, familyMapCategories } from '../data/vigo-family';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const points = familyMapPoints.map(p => ({ n: p.name, c: p.category, lat: p.lat, lng: p.lng }));
const colors = Object.fromEntries(familyMapCategories.map(c => [c.key, c.color]));
---

<div class="reveal">
  <h2 class="font-display text-2xl font-bold text-gray-900 mb-4">{t(lang, 'family.mapTitle')}</h2>

  <div class="flex flex-wrap gap-x-5 gap-y-2 mb-4">
    {familyMapCategories.map(cat => (
      <span class="inline-flex items-center gap-2 text-sm text-gray-600">
        <span class="w-3 h-3 rounded-full ring-2 ring-white shadow" style={`background:${cat.color}`}></span>
        {cat.label[lang] ?? cat.label.es}
      </span>
    ))}
  </div>

  <div class="relative z-0 rounded-2xl overflow-hidden shadow-lift border hairline">
    <div id="family-map" class="h-[380px] sm:h-[520px] w-full bg-primary-100"></div>
  </div>

  <script type="application/json" id="family-map-data" set:html={JSON.stringify({ points, colors })}></script>
</div>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  const el = document.getElementById('family-map');
  const dataEl = document.getElementById('family-map-data');
  if (el && dataEl) {
    const { points, colors } = JSON.parse(dataEl.textContent || '{}');

    const map = L.map(el, { scrollWheelZoom: false, zoomControl: true });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 18,
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    }).addTo(map);

    const bounds: [number, number][] = [];
    for (const p of points) {
      const marker = L.circleMarker([p.lat, p.lng], {
        radius: 8,
        color: '#ffffff',
        weight: 2,
        fillColor: colors[p.c] || '#1f7db0',
        fillOpacity: 1,
      }).addTo(map);
      marker.bindPopup('<strong>' + p.n + '</strong>', { closeButton: false });
      marker.on('mouseover', () => marker.openPopup());
      bounds.push([p.lat, p.lng]);
    }

    if (bounds.length) {
      map.fitBounds(bounds, { padding: [36, 36] });
    } else {
      map.setView([42.23, -8.72], 12);
    }

    // Re-measure once fonts/layout settle (avoids grey tiles on first paint)
    setTimeout(() => map.invalidateSize(), 200);
  }
</script>
