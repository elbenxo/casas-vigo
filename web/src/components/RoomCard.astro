---
import { t, getLocalePath, type Lang } from '../i18n/translations';
import type { Room } from '../data/flats';
import { SOON_DAYS } from '../data/flats';
import type { I18nText } from '../i18n/translations';

interface Props {
  room: Room;
  flatName: I18nText;
  lang: Lang;
  contactPath: string;
}

const { room, flatName, lang, contactPath } = Astro.props;

const today = new Date();
today.setHours(0, 0, 0, 0);
const soonMs = SOON_DAYS * 24 * 60 * 60 * 1000;

let availableSoon = false;
let formattedDate: string | null = null;

if (!room.available && room.available_from) {
  const fromDate = new Date(room.available_from);
  availableSoon = (fromDate.getTime() - today.getTime()) <= soonMs;
  // Format date locale-appropriately: DD/MM/YYYY for most, YYYY.MM.DD for Korean
  if (lang === 'ko') {
    const y = fromDate.getUTCFullYear();
    const m = String(fromDate.getUTCMonth() + 1).padStart(2, '0');
    const d = String(fromDate.getUTCDate()).padStart(2, '0');
    formattedDate = `${y}.${m}.${d}`;
  } else {
    const d = String(fromDate.getUTCDate()).padStart(2, '0');
    const m = String(fromDate.getUTCMonth() + 1).padStart(2, '0');
    const y = fromDate.getUTCFullYear();
    formattedDate = `${d}/${m}/${y}`;
  }
}

// Badge styles
const badgeClass = room.available
  ? 'bg-green-100 text-green-700'
  : availableSoon
    ? 'bg-amber-100 text-amber-700'
    : 'bg-gray-100 text-gray-500';

const badgeText = room.available
  ? t(lang, 'flats.available')
  : availableSoon
    ? t(lang, 'flats.availableSoon')
    : t(lang, 'flats.occupied');
---

<div class="bg-white rounded-xl shadow-soft overflow-hidden border border-gray-100/80 hover:shadow-lift hover:-translate-y-1 transition-all duration-300">
  {room.images.length > 0 && (
    <div class="aspect-[16/10] bg-primary-50 relative overflow-hidden img-zoom">
      <img
        src={room.images[0]}
        alt={`${room.name[lang]} en ${flatName[lang]}, Vigo`}
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-6">
    <div class="flex items-center justify-between mb-3">
      <h3 class="font-semibold text-gray-900">{room.name[lang]}</h3>
      <span class:list={['text-xs font-semibold px-2 py-1 rounded-full', badgeClass]}>
        {badgeText}
      </span>
    </div>
    <p class="text-2xl font-bold text-primary-700">
      {room.price}&euro;<span class="text-sm font-normal text-gray-500">{t(lang, 'flats.month')}</span>
    </p>
    <p class="text-sm text-gray-500 mt-1">{room.size}</p>
    {!room.available && formattedDate && (
      <p class="text-sm text-amber-600 mt-2 font-medium">
        {t(lang, 'flats.availableFrom')}: {formattedDate}
      </p>
    )}
    <ul class="mt-3 space-y-1">
      {room.features.map(f => (
        <li class="text-sm text-gray-600 flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-primary-400 rounded-full"></span>
          {f}
        </li>
      ))}
    </ul>
    {room.available && (
      <a
        href={contactPath}
        class="mt-4 block text-center bg-primary-600 hover:bg-primary-700 text-white font-medium py-2.5 rounded-lg transition-all duration-300 text-sm hover:shadow-md"
      >
        {t(lang, 'flat.contact')}
      </a>
    )}
  </div>
</div>
