---
import Layout from '../../../../layouts/Layout.astro';
import FamilyGuide from '../../../../components/FamilyGuide.astro';
import { t } from '../../../../i18n/translations';
import { generateFamilyJsonLd } from '../../../../data/vigo-family';

const lang = 'de';
---

<Layout
  title={t(lang, 'family.title')}
  description={t(lang, 'family.subtitle')}
  lang={lang}
  path="/vigo/familias/"
  jsonLd={generateFamilyJsonLd(lang)}
>
  <FamilyGuide lang={lang} />
</Layout>
